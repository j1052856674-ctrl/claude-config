          { "id": "bilibili_tech", "site": "bilibili.com", "metric": "播放+弹幕+三连", "access": "playwright", "login_required": false, "note": "技术评测视频（文本提取有限，以标题+简介+评论为主）" },
          { "id": "twitter_tech", "site": "twitter.com", "metric": "likes+retweets+verified", "access": "playwright+websearch", "login_required": "partial" }
        ]
      }
    },

