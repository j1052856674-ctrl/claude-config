          { "id": "juejin", "site": "juejin.cn", "metric": "点赞+收藏", "access": "playwright", "login_required": false, "note": "中文开发者社区" },
          { "id": "csdn", "site": "csdn.net", "metric": "阅读量+评论", "access": "playwright", "login_required": false, "note": "中文最大开发者社区（质量参差，需综合判断）" },
