{
  "_meta": {
    "version": "3.0-draft",
    "description": "deep-research v3 权威数据源分层配置。新增：中文UGC平台、消费/医疗/金融等领域、按需源路由匹配引擎。",
    "principle": "L1优先→L2补充→L3交叉验证。按研究问题领域自动匹配源，而非全量轰炸。",
    "search_strategy": "source_routing — 先判定领域 → 匹配源清单 → 限定源内搜索 → 交叉验证"
  },

  "source_routing": {
    "_note": "按研究问题的领域+语言+深度自动匹配源策略。非每次都全源轰炸。",
    "rules": [
      {
        "when": { "domain": "tech_framework", "lang": "any" },
        "sources": ["github", "pypi", "npm", "stackoverflow", "zhihu(tech)", "juejin", "csdn", "hackernews", "reddit(programming)"],
        "max_sources": 5,
        "note": "技术选型：开源数据为主，中文社区为辅"
      },
      {
        "when": { "domain": "academic_research", "lang": "any" },
        "sources": ["arxiv", "semantic_scholar", "paperswithcode", "google_scholar", "zhihu(academic)"],
        "max_sources": 5,
        "note": "学术：预印本+引用图，中文场景追加知乎学术圈"
      },
      {
        "when": { "domain": "market_industry", "lang": "zh" },
        "sources": ["stats_gov_cn", "36kr", "huxiu", "cbinsights", "crunchbase", "zhihu(business)", "linkedin", "maimai"],
        "max_sources": 6,
        "note": "中文市场分析：中国官方数据+科技媒体+职场平台"
      },
      {
        "when": { "domain": "market_industry", "lang": "en" },
        "sources": ["sec_edgar", "worldbank", "gartner", "statista", "mckinsey", "bloomberg", "reuters"],
        "max_sources": 5,
        "note": "英文市场分析：财报+国际组织+咨询公司"
      },
      {
        "when": { "domain": "consumer_product", "lang": "zh" },
        "sources": ["xiaohongshu", "zhihu(shopping)", "douban", "bilibili(review)", "weibo", "amazon_cn", "jd"],
        "max_sources": 5,
        "note": "消费决策：UGC评测+电商评价"
      },
      {
        "when": { "domain": "consumer_product", "lang": "en" },
        "sources": ["reddit", "youtube(review)", "amazon", "trustpilot", "twitter", "producthunt"],
        "max_sources": 5,
        "note": "消费决策：Reddit+YouTube+电商"
      },
      {
        "when": { "domain": "career_job", "lang": "zh" },
        "sources": ["maimai", "zhihu(career)", "linkedin", "lagou", "boss_zhipin"],
        "max_sources": 4,
        "note": "职场调研：脉脉+知乎+招聘平台"
      },
      {
        "when": { "domain": "healthcare", "lang": "any" },
        "sources": ["pubmed", "fda", "who", "cochrane", "clinicaltrials"],
        "max_sources": 4,
        "note": "医疗健康：仅权威医学源，禁用UGC"
      },
      {
        "when": { "domain": "finance_investment", "lang": "any" },
        "sources": ["yahoo_finance", "sec_edgar", "fred", "bloomberg", "reuters"],
        "max_sources": 4,
        "note": "金融投资：一级市场数据为主"
      },
      {
        "when": { "domain": "tech_trends", "lang": "any" },
        "sources": ["github_trending", "arxiv", "thoughtworks_radar", "stackoverflow_survey", "stateofjs", "hackernews", "36kr", "zhihu(tech)"],
        "max_sources": 5,
        "note": "技术趋势：多源信号汇聚"
      },
      {
        "when": { "domain": "regulation_policy", "lang": "zh" },
        "sources": ["gov_cn", "pkulaw", "europa", "iapp"],
        "max_sources": 4,
        "note": "政策法规：政府源优先，禁用社媒"
      },
      {
        "when": { "domain": "security_vulnerability", "lang": "any" },
        "sources": ["nvd", "cve", "github_advisories", "exploit_db", "mitre_attack", "snyk"],
        "max_sources": 5,
        "note": "安全：仅权威漏洞库"
      }
    ],
    "default_fallback": {
      "sources": ["wikipedia", "websearch_broad"],
      "max_sources": 3,
      "note": "无法匹配领域时：Wikipedia概述 + 泛搜发现"
    }
  },

  "domains": {
    "tech_framework": {
      "label": "技术框架选型",
      "keywords": ["框架", "framework", "library", "SDK", "语言", "language", "对比", "comparison", "选型", "替代", "alternative", "开源", "open source"],
